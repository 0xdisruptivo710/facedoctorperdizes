---
/**
 * Definition v3.1 - "O que é" - bloco editorial sobre fundo claro.
 */
interface Props {
  eyebrow: string;
  lead: string;
  footnote?: string;
}

const { eyebrow, lead, footnote } = Astro.props;
---

<section class="definition-v3">
  <div class="container container--default definition-v3__inner">
    <p class="definition-v3__eyebrow">{eyebrow}</p>
    <p class="definition-v3__lead reveal">{lead}</p>
    {footnote && <p class="definition-v3__footnote reveal" style="--reveal-delay: 1">{footnote}</p>}
  </div>
</section>

<style>
  .definition-v3 {
    background-color: var(--brand-light);
    color: var(--brand-dark);
    padding-block: clamp(4rem, 8vh, 7rem);
    border-block-start: 1px solid var(--border-faint);
  }

  .definition-v3__inner {
    max-width: 56rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .definition-v3__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: var(--track-mono);
    color: var(--brand-accent);
    position: relative;
    padding-inline-start: 2.5rem;
    margin-block-end: var(--space-3);
  }
  .definition-v3__eyebrow::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 50%;
    width: 1.5rem;
    height: 1px;
    background-color: var(--brand-accent);
  }

  .definition-v3__lead {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: var(--weight-regular);
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    line-height: 1.3;
    color: var(--brand-dark);
    letter-spacing: var(--track-h2);
  }

  .definition-v3__footnote {
    font-family: var(--font-sans);
    font-weight: var(--weight-light);
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: var(--leading-body);
    border-block-start: 1px solid var(--border-faint);
    padding-block-start: var(--space-5);
    margin-block-start: var(--space-3);
  }
</style>
