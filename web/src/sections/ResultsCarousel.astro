---
/**
 * ResultsCarousel v3.1 - Antes/Depois real da clínica em formato editorial.
 * As fotos já são compostas (lado-a-lado ou grid). Exibe imagem composta + tag de tratamento + caption.
 */
interface ResultItem {
  src: string;
  alt: string;
  procedure: string;
  caption: string;
  layout?: 'horizontal' | 'vertical' | 'grid';
}

interface Props {
  headline?: string;
  eyebrow?: string;
  items: ResultItem[];
  variant?: 'light' | 'dark';
}

const {
  headline = 'Resultados reais.',
  eyebrow = 'Antes & Depois',
  items,
  variant = 'light',
} = Astro.props;
---

<section class:list={["results-v3", `results-v3--${variant}`]}>
  <div class="container container--wide results-v3__inner">
    <header class="results-v3__head">
      <p class="results-v3__eyebrow">{eyebrow}</p>
      <h2 class="results-v3__title">{headline}</h2>
      <p class="results-v3__disclaimer">
        Pacientes reais da unidade Perdizes. Resultados variam conforme
        anatomia, protocolo e adesão ao plano de tratamento.
      </p>
    </header>

    <div class="results-v3__track" data-results-track>
      {items.map((item, i) => (
        <article class="results-v3__card reveal" style={`--reveal-delay: ${i % 4}`}>
          <figure class="results-v3__media" data-layout={item.layout ?? 'horizontal'}>
            <img src={item.src} alt={item.alt} loading="lazy" />
            <div class="results-v3__labels" aria-hidden="true" data-layout={item.layout ?? 'horizontal'}>
              <span class="results-v3__label">Antes</span>
              <span class="results-v3__label">Depois</span>
            </div>
          </figure>
          <footer class="results-v3__caption">
            <span class="results-v3__tag">{item.procedure}</span>
            <p class="results-v3__text">{item.caption}</p>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .results-v3 {
    padding-block: clamp(5rem, 10vh, 8rem);
  }
  .results-v3--light {
    background-color: var(--brand-light);
    color: var(--brand-dark);
  }
  .results-v3--dark {
    background-color: var(--brand-dark);
    color: var(--brand-light);
  }

  .results-v3__head {
    margin-block-end: var(--space-9);
    max-width: 56rem;
  }

  .results-v3__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: var(--track-mono);
    color: var(--brand-gold);
    margin-block-end: var(--space-3);
  }

  .results-v3__title {
    font-family: var(--font-serif);
    font-weight: var(--weight-regular);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    letter-spacing: var(--track-tight);
    line-height: 1;
    margin-block-end: var(--space-5);
  }

  .results-v3__disclaimer {
    font-family: var(--font-sans);
    font-weight: var(--weight-light);
    font-size: var(--text-sm);
    line-height: var(--leading-body);
    color: var(--text-muted);
    max-width: 32rem;
  }
  .results-v3--dark .results-v3__disclaimer { color: rgba(250, 248, 247, 0.6); }

  /* Track - horizontal scroll on mobile, grid on desktop */
  .results-v3__track {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }
  @media (min-width: 700px) {
    .results-v3__track {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-7) var(--space-6);
    }
  }
  @media (min-width: 1100px) {
    .results-v3__track {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .results-v3__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .results-v3__media {
    position: relative;
    overflow: hidden;
    background-color: var(--brand-dark);
    border: 1px solid var(--border-faint);
  }
  .results-v3--dark .results-v3__media { border-color: var(--border-dark); }

  .results-v3__media[data-layout="horizontal"] { aspect-ratio: 1 / 1; }
  .results-v3__media[data-layout="vertical"]   { aspect-ratio: 3 / 4; }
  .results-v3__media[data-layout="grid"]       { aspect-ratio: 1 / 1; }

  .results-v3__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 1200ms var(--ease-out);
  }
  .results-v3__card:hover .results-v3__media img { transform: scale(1.04); }

  /* Antes/Depois labels overlay */
  .results-v3__labels {
    position: absolute;
    inset: 0;
    display: grid;
    pointer-events: none;
    padding: var(--space-4);
  }
  .results-v3__labels[data-layout="horizontal"] {
    grid-template-columns: 1fr 1fr;
    align-items: end;
  }
  .results-v3__labels[data-layout="vertical"] {
    grid-template-rows: 1fr 1fr;
    align-items: end;
    justify-items: start;
  }
  .results-v3__labels[data-layout="grid"] {
    grid-template-columns: 1fr 1fr;
    align-items: end;
  }
  .results-v3__labels[data-layout="grid"] .results-v3__label:nth-child(1) { grid-column: 1; }
  .results-v3__labels[data-layout="grid"] .results-v3__label:nth-child(2) { grid-column: 2; }

  .results-v3__label {
    display: inline-block;
    padding: 0.4rem 0.7rem;
    background-color: rgba(31, 27, 28, 0.85);
    backdrop-filter: blur(6px);
    color: var(--brand-light);
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--track-mono);
    border-radius: var(--radius-xs);
    justify-self: start;
  }
  .results-v3__labels[data-layout="horizontal"] .results-v3__label:last-child {
    justify-self: end;
  }

  /* Caption */
  .results-v3__caption {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .results-v3__tag {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--track-mono);
    color: var(--brand-gold);
  }

  .results-v3__text {
    font-family: var(--font-sans);
    font-weight: var(--weight-light);
    font-size: var(--text-base);
    line-height: var(--leading-body);
    color: inherit;
  }
  .results-v3--dark .results-v3__text { color: rgba(250, 248, 247, 0.75); }
</style>
