---
/**
 * CtaCine v3.1 - CTA cinematic em fundo dark com headline serif gigante.
 */
interface Props {
  headline: string;
  lead: string;
  ctaHref: string;
  ctaLabel?: string;
}

const { headline, lead, ctaHref, ctaLabel = 'Falar com Concierge via WhatsApp' } = Astro.props;
---

<section class="cta-cine">
  <div class="container container--default cta-cine__inner">
    <h2 class="cta-cine__title reveal" set:html={headline} />
    <p class="cta-cine__lead reveal" style="--reveal-delay: 1">{lead}</p>

    <a
      href={ctaHref}
      target="_blank"
      rel="noopener noreferrer"
      class="cta-cine__button reveal"
      style="--reveal-delay: 2"
    >
      {ctaLabel}
    </a>

    <p class="cta-cine__meta reveal" style="--reveal-delay: 3">Resposta média em 5 minutos.</p>
  </div>
</section>

<style>
  .cta-cine {
    background-color: var(--brand-dark);
    color: var(--brand-light);
    padding-block: clamp(5rem, 10vh, 8rem);
    position: relative;
    overflow: hidden;
  }

  .cta-cine::before {
    content: "";
    position: absolute;
    inset-block-start: -20%;
    inset-inline-start: -20%;
    width: 70%;
    height: 140%;
    background-image: radial-gradient(circle at center, rgba(187, 160, 114, 0.08), transparent 70%);
    pointer-events: none;
  }

  .cta-cine__inner {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }

  .cta-cine__title {
    font-family: var(--font-serif);
    font-weight: var(--weight-regular);
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    letter-spacing: var(--track-tight);
    line-height: 0.95;
    color: var(--brand-light);
    max-width: 22ch;
  }
  .cta-cine__title em { font-style: italic; color: var(--brand-gold); }

  .cta-cine__lead {
    font-family: var(--font-sans);
    font-weight: var(--weight-light);
    font-size: var(--text-lg);
    color: rgba(250, 248, 247, 0.7);
    max-width: 36rem;
    line-height: var(--leading-body);
  }

  .cta-cine__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--brand-primary);
    color: #fff;
    padding: 1.25rem 2.5rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--track-button);
    box-shadow: 0 20px 40px -10px rgba(197, 118, 127, 0.4);
    transition: background-color var(--dur-base) var(--ease-out),
                transform var(--dur-fast) var(--ease-snap);
    margin-block-start: var(--space-4);
  }
  .cta-cine__button:hover { background-color: var(--brand-accent); }
  .cta-cine__button:active { transform: scale(0.98); }

  .cta-cine__meta {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: var(--track-mono);
    color: var(--brand-gold);
    margin-block-start: var(--space-3);
  }
</style>
