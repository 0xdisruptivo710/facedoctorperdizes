---
/**
 * Bento gallery 4 imagens, proporções variadas, fundo ink.
 * DESIGN.md §6.1 step 5.
 */
import Eyebrow from '../../components/Eyebrow.astro';

interface ShotItem {
  src: string;
  alt: string;
  caption: string;
}

const shots: ShotItem[] = [
  // TODO[asset]: 4 fotos reais da unidade Perdizes (§8.1)
  {
    src: 'https://images.unsplash.com/photo-1616486029423-aaa4789e8c9a?auto=format&fit=crop&q=80&w=1600',
    alt: 'Recepção da unidade Perdizes',
    caption: '01 / Recepção',
  },
  {
    src: 'https://images.unsplash.com/photo-1628108990666-410a5611ea89?auto=format&fit=crop&q=80&w=600',
    alt: 'Detalhe de instrumentos e superfície',
    caption: '02 / Detalhe',
  },
  {
    src: 'https://images.unsplash.com/photo-1599723226756-7ee61a6c117b?auto=format&fit=crop&q=80&w=600',
    alt: 'Mãos da equipe em aplicação',
    caption: '03 / Prática',
  },
  {
    src: 'https://images.unsplash.com/photo-1631815588090-d4bfec5b1ccf?auto=format&fit=crop&q=80&w=1600',
    alt: 'Sala de aplicação com luz natural',
    caption: '04 / Sala',
  },
];
---

<section id="clinica" class="section section--dark section--divided bento bg-noise">
  <div class="container container--wide">
    <header class="bento__head reveal">
      <h2 class="display bento__title">O espaço</h2>
      <Eyebrow tone="light">Unidade Perdizes</Eyebrow>
    </header>

    <div class="bento__grid">
      {shots.map((shot, i) => (
        <figure class={`bento__cell bento__cell--${i + 1} reveal`} style={`--reveal-delay: ${i}`}>
          <img src={shot.src} alt={shot.alt} loading="lazy" />
          <figcaption class="mono bento__caption">{shot.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .bento__head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    flex-wrap: wrap;
    gap: var(--space-5);
    margin-block-end: var(--space-9);
  }
  .bento__title {
    font-size: clamp(2.5rem, 5vw, 5rem);
    color: var(--paper);
  }

  .bento__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    grid-auto-rows: 200px;
  }
  @media (min-width: 768px) {
    .bento__grid {
      grid-template-columns: repeat(12, 1fr);
      gap: var(--space-4);
      grid-auto-rows: 300px;
    }
  }

  .bento__cell {
    position: relative;
    overflow: hidden;
    margin: 0;
  }
  .bento__cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-cine) var(--ease-out);
  }
  .bento__cell:hover img { transform: scale(1.05); }

  @media (min-width: 768px) {
    .bento__cell--1 { grid-column: span 8; grid-row: span 2; }
    .bento__cell--2 { grid-column: span 4; }
    .bento__cell--3 { grid-column: span 4; }
    .bento__cell--4 { grid-column: span 12; }
  }

  .bento__caption {
    position: absolute;
    inset-block-end: var(--space-4);
    inset-inline-end: var(--space-4);
    padding: 4px 8px;
    background-color: rgba(26, 22, 20, 0.8);
    color: var(--paper);
    font-size: 10px;
    backdrop-filter: blur(4px);
  }
</style>
