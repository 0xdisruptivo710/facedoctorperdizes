---
/**
 * Clinic v3.1 - Refúgio em Perdizes, com stack de imagens e número outline 03.
 */
import { CLINIC } from '../../lib/clinic';
---

<section id="experiencia" class="clinic-v3">
  <div class="container container--wide clinic-v3__inner">
    <div class="clinic-v3__media reveal">
      <figure class="clinic-v3__media-primary">
        <img
          src="/clinica/clinica-1.avif"
          alt="Interior da Face Doctor Perdizes - arquitetura sofisticada e acolhedora"
          loading="lazy"
        />
      </figure>
      <figure class="clinic-v3__media-overlap">
        <img
          src="/clinica/clinica-2.avif"
          alt="Detalhe do ambiente da clínica Face Doctor Perdizes"
          loading="lazy"
        />
      </figure>
    </div>

    <div class="clinic-v3__body reveal">
      <span class="clinic-v3__outline outline-num" aria-hidden="true">03</span>

      <div class="clinic-v3__body-inner">
        <h2 class="clinic-v3__title">
          O Refúgio<br />
          <em>em {CLINIC.address.neighborhood}.</em>
        </h2>
        <p class="clinic-v3__lead">
          Localizada no coração de {CLINIC.address.neighborhood}, {CLINIC.address.city},
          nossa unidade foi arquitetada para ser um oásis de tranquilidade.
          Longe do aspecto hospitalar frio, criamos um ambiente sensorial
          que acolhe você desde o primeiro café até o pós-procedimento.
        </p>

        <ul class="clinic-v3__features">
          <li class="clinic-v3__feature">
            <span class="clinic-v3__feature-bullet" aria-hidden="true"></span>
            <div>
              <h4 class="clinic-v3__feature-title">Corpo Clínico Especializado</h4>
              <p class="clinic-v3__feature-body">
                Profissionais de excelência, com alta qualificação e
                treinamento constante nas tecnologias mais recentes
                do mercado global.
              </p>
            </div>
          </li>
          <li class="clinic-v3__feature">
            <span class="clinic-v3__feature-bullet" aria-hidden="true"></span>
            <div>
              <h4 class="clinic-v3__feature-title">Produtos Premium</h4>
              <p class="clinic-v3__feature-body">
                Trabalhamos exclusivamente com marcas consagradas
                cientificamente - Allergan, Merz, Galderma -
                garantindo máxima segurança.
              </p>
            </div>
          </li>
        </ul>

        <p class="clinic-v3__address">
          {CLINIC.address.street} · {CLINIC.address.neighborhood} ·
          {CLINIC.address.city}, {CLINIC.address.state}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .clinic-v3 {
    background-color: #fff;
    color: var(--brand-dark);
    padding-block: clamp(6rem, 12vh, 10rem);
    position: relative;
  }

  .clinic-v3__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-9);
    align-items: center;
  }
  @media (min-width: 900px) {
    .clinic-v3__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }
  }

  /* Media stack */
  .clinic-v3__media {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
  }
  @media (min-width: 900px) {
    .clinic-v3__media { aspect-ratio: auto; min-height: 32rem; }
  }

  .clinic-v3__media-primary {
    position: relative;
    z-index: 1;
    width: 80%;
    margin-inline-start: auto;
    aspect-ratio: 3 / 4;
    box-shadow: var(--shadow-lift);
    overflow: hidden;
  }
  .clinic-v3__media-primary img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.05) brightness(0.95);
  }

  .clinic-v3__media-overlap {
    position: absolute;
    inset-block-end: 3rem;
    inset-inline-start: 0;
    z-index: 2;
    width: 60%;
    aspect-ratio: 1 / 1;
    background-color: var(--brand-light);
    padding: var(--space-3);
    box-shadow: var(--shadow-soft);
    transform: translateX(-1.5rem);
    overflow: hidden;
  }
  @media (min-width: 900px) {
    .clinic-v3__media-overlap { transform: translateX(-3rem); width: 60%; }
  }
  .clinic-v3__media-overlap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Body */
  .clinic-v3__body {
    position: relative;
    padding-block-start: var(--space-7);
  }
  @media (min-width: 900px) {
    .clinic-v3__body { padding-inline-start: var(--space-6); }
  }

  .clinic-v3__outline {
    display: none;
    position: absolute;
    inset-block-start: 1rem;
    inset-inline-end: 1rem;
    z-index: 0;
    pointer-events: none;
  }
  @media (min-width: 900px) { .clinic-v3__outline { display: block; } }

  .clinic-v3__body-inner { position: relative; z-index: 1; }

  .clinic-v3__title {
    font-family: var(--font-serif);
    font-weight: var(--weight-regular);
    font-size: clamp(2.25rem, 4vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: var(--track-h2);
    color: var(--brand-dark);
    margin-block-end: var(--space-5);
  }
  .clinic-v3__title em {
    font-style: italic;
    color: var(--brand-primary);
  }

  .clinic-v3__lead {
    font-family: var(--font-sans);
    font-weight: var(--weight-light);
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin-block-end: var(--space-7);
    max-width: 36rem;
  }

  .clinic-v3__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-block-end: var(--space-7);
  }
  .clinic-v3__feature {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: flex-start;
  }
  .clinic-v3__feature-bullet {
    width: 8px;
    height: 8px;
    margin-block-start: 0.5rem;
    border-radius: var(--radius-full);
    background-color: var(--brand-accent);
    flex-shrink: 0;
  }
  .clinic-v3__feature-title {
    font-family: var(--font-sans);
    font-weight: var(--weight-medium);
    font-size: var(--text-base);
    color: var(--brand-dark);
    margin-block-end: var(--space-2);
  }
  .clinic-v3__feature-body {
    font-family: var(--font-sans);
    font-weight: var(--weight-light);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-body);
    max-width: 32rem;
  }

  .clinic-v3__address {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: var(--track-mono);
    color: var(--brand-accent);
    border-block-start: 1px solid var(--border-faint);
    padding-block-start: var(--space-4);
  }
</style>
