---
/**
 * Home Hero — asymmetric, headline 8 cols + portrait 4 cols 4:5.
 * DESIGN.md §6.1 step 1.
 */
import Button from '../../components/Button.astro';

interface Props {
  primaryHref: string;
}
const { primaryHref } = Astro.props;
---

<section class="home-hero bg-noise">
  <div class="container container--wide home-hero__grid">
    <div class="home-hero__copy">
      <h1 class="display display--hero home-hero__headline reveal" style="--reveal-delay: 1">
        A pele certa para você &mdash;<br />é a que você já tem,<br />em outra década.
      </h1>
      <p class="body home-hero__lead reveal" style="--reveal-delay: 3">
        Uma abordagem editorial à medicina estética facial. Protocolos minimalistas, precisão técnica e resultados que respeitam a sua identidade estrutural.
      </p>
    </div>

    <figure class="home-hero__portrait reveal" style="--reveal-delay: 2">
      <div class="img-frame img-frame--portrait-4x5">
        <!-- TODO[asset]: substituir por foto editorial própria (§8.1) -->
        <img
          class="img-parallax"
          src="https://images.unsplash.com/photo-1544502062-f82887f03d1c?auto=format&fit=crop&q=80&w=1200"
          alt="Retrato editorial de mulher 40+ com pele natural e iluminação suave"
          loading="eager"
          width="1200"
          height="1500"
        />
      </div>
      <figcaption class="home-hero__meta mono">
        <span>Fig. 01 — Estrutura</span>
        <Button href={primaryHref} variant="link" external>Avaliação inicial →</Button>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .home-hero {
    min-height: 100dvh;
    padding-block: var(--space-10) var(--space-7);
    display: flex;
    align-items: center;
  }
  .home-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: end;
    width: 100%;
  }
  @media (min-width: 900px) {
    .home-hero__grid {
      grid-template-columns: 8fr 4fr;
      gap: var(--space-7);
    }
  }
  .home-hero__copy { order: 2; }
  .home-hero__portrait { order: 1; }
  @media (min-width: 900px) {
    .home-hero__copy { order: 1; }
    .home-hero__portrait { order: 2; }
  }

  .home-hero__lead {
    color: var(--ink-soft);
    max-width: 44ch;
    margin-block-start: var(--space-7);
  }
  @media (max-width: 767px) {
    .home-hero__lead { display: none; }
  }

  .home-hero__portrait {
    margin: 0;
    width: 100%;
  }
  @media (min-width: 900px) {
    .home-hero__portrait .img-frame { margin-inline-start: auto; }
  }
  .home-hero__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--ink-soft);
    opacity: 0.7;
    margin-block-start: var(--space-5);
  }
</style>
