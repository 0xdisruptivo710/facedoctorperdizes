---
/**
 * Antes/depois drag-to-reveal - uma única imagem hero.
 * DESIGN.md §6.2 step 6.
 * TODO[asset]: substituir por caso real autorizado (§8.1, compliance ANVISA/CFM).
 */
import Eyebrow from '../../components/Eyebrow.astro';

interface Props {
  before: { src: string; alt: string };
  after:  { src: string; alt: string };
  beforeLabel?: string;
  afterLabel?: string;
}

const {
  before,
  after,
  beforeLabel = 'Antes',
  afterLabel = '90 dias',
} = Astro.props;
---

<section class="section section--divided ba">
  <div class="container container--default">
    <header class="ba__head reveal">
      <Eyebrow>Resultado</Eyebrow>
      <h2 class="display ba__title">Veja por baixo.</h2>
      <p class="body ba__lead">Caso real, autorizado. Arraste para comparar.</p>
    </header>

    <div class="ba__slider reveal" data-ba-slider>
      <img class="ba__img ba__img--before" src={before.src} alt={before.alt} loading="lazy" />
      <img class="ba__img ba__img--after"  src={after.src}  alt={after.alt}  loading="lazy" />
      <span class="ba__label ba__label--start mono">{beforeLabel}</span>
      <span class="ba__label ba__label--end mono">{afterLabel}</span>
      <button
        class="ba__handle"
        type="button"
        aria-label="Arraste para comparar antes e depois"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="50"
        role="slider"
      >
        <span aria-hidden="true">‹ ›</span>
      </button>
    </div>
  </div>
</section>

<style>
  .ba__head {
    margin-block-end: var(--space-8);
  }
  .ba__head :global(.eyebrow) { margin-block-end: var(--space-5); }
  .ba__title {
    font-size: clamp(2.5rem, 5vw, 5rem);
    margin-block-end: var(--space-4);
  }
  .ba__lead {
    color: var(--ink-soft);
    max-width: 36ch;
  }

  .ba__slider {
    position: relative;
    aspect-ratio: 4 / 3;
    background-color: var(--ink);
    overflow: hidden;
    user-select: none;
    touch-action: none;
    cursor: ew-resize;
  }
  .ba__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ba__img--after {
    clip-path: inset(0 0 0 50%);
    transition: clip-path 100ms linear;
  }

  .ba__label {
    position: absolute;
    inset-block-start: var(--space-4);
    padding: 4px 8px;
    background-color: rgba(26, 22, 20, 0.8);
    color: var(--paper);
    font-size: 10px;
    z-index: 2;
    backdrop-filter: blur(4px);
  }
  .ba__label--start { inset-inline-start: var(--space-4); }
  .ba__label--end   { inset-inline-end:   var(--space-4); }

  .ba__handle {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 50%;
    width: 2px;
    background: var(--paper);
    transform: translateX(-50%);
    z-index: 3;
    padding: 0;
    border: 0;
    cursor: ew-resize;
  }
  .ba__handle::before {
    content: '';
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: 50%;
    width: 48px;
    height: 48px;
    background-color: var(--ink);
    border: 1px solid var(--paper);
    border-radius: var(--radius-pill);
    transform: translate(-50%, -50%);
  }
  .ba__handle span {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: 50%;
    transform: translate(-50%, -50%);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.1em;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-ba-slider]').forEach((slider) => {
    const after = slider.querySelector<HTMLElement>('.ba__img--after');
    const handle = slider.querySelector<HTMLElement>('.ba__handle');
    if (!after || !handle) return;

    let dragging = false;
    const setPos = (pct: number) => {
      const v = Math.max(0, Math.min(100, pct));
      after.style.clipPath = `inset(0 0 0 ${v}%)`;
      handle.style.insetInlineStart = `${v}%`;
      handle.setAttribute('aria-valuenow', String(Math.round(v)));
    };
    setPos(50);

    const updateFromEvent = (e: MouseEvent | TouchEvent) => {
      const rect = slider.getBoundingClientRect();
      const clientX = 'touches' in e ? e.touches[0]!.clientX : e.clientX;
      setPos(((clientX - rect.left) / rect.width) * 100);
    };

    slider.addEventListener('mousedown', (e) => { dragging = true; updateFromEvent(e); });
    slider.addEventListener('touchstart', (e) => { dragging = true; updateFromEvent(e); }, { passive: true });
    window.addEventListener('mousemove', (e) => { if (dragging) updateFromEvent(e); });
    window.addEventListener('touchmove', (e) => { if (dragging) updateFromEvent(e); }, { passive: true });
    window.addEventListener('mouseup',   () => { dragging = false; });
    window.addEventListener('touchend',  () => { dragging = false; });

    // Keyboard: ←/→ to move
    handle.addEventListener('keydown', (e: KeyboardEvent) => {
      const current = Number(handle.getAttribute('aria-valuenow') ?? 50);
      if (e.key === 'ArrowLeft')  { setPos(current - 2); e.preventDefault(); }
      if (e.key === 'ArrowRight') { setPos(current + 2); e.preventDefault(); }
    });
  });
</script>
