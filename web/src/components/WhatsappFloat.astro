---
/**
 * WhatsappFloat v3.1 — pill em brand-accent (mauve), nunca verde.
 * Aparece após 400px de scroll.
 */
import { whatsappUrl, WA_MESSAGES } from '../lib/clinic';

interface Props {
  message?: string;
  label?: string;
}
const { message = WA_MESSAGES.general, label = 'Agendar Avaliação' } = Astro.props;
---

<a
  class="wa-float"
  href={whatsappUrl(message)}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Falar no WhatsApp"
  data-visible="false"
>
  <span class="wa-float__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.149-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
    </svg>
  </span>
  <span class="wa-float__label">{label}</span>
</a>

<style>
  .wa-float {
    position: fixed;
    inset-block-end: var(--space-5);
    inset-inline-end: var(--space-5);
    z-index: var(--z-whatsapp);

    display: inline-flex;
    align-items: center;
    gap: var(--space-3);

    background-color: var(--brand-accent);
    color: #fff;
    padding: 14px 18px;
    border-radius: var(--radius-pill);
    box-shadow: 0 20px 40px -10px rgba(168, 100, 105, 0.45);

    opacity: 0;
    transform: translateY(20px) scale(0.95);
    pointer-events: none;
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out),
      background-color var(--dur-base) var(--ease-out);
  }

  .wa-float[data-visible="true"] {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .wa-float:hover { background-color: var(--brand-primary); }
  .wa-float:active { transform: scale(0.97); }

  .wa-float__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  .wa-float__label {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: var(--weight-medium);
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    transition: max-width var(--dur-slow) var(--ease-out),
                margin-inline-start var(--dur-slow) var(--ease-out);
    margin-inline-start: 0;
  }

  @media (max-width: 767px) {
    .wa-float__label { max-width: 160px; }
  }

  @media (min-width: 768px) {
    .wa-float { padding: 16px; }
    .wa-float:hover .wa-float__label,
    .wa-float:focus-visible .wa-float__label {
      max-width: 180px;
      margin-inline-start: var(--space-2);
    }
  }
</style>

<script>
  const float = document.querySelector<HTMLAnchorElement>('.wa-float');
  if (float) {
    const reveal = () => {
      float.dataset.visible = window.scrollY > 400 ? 'true' : 'false';
    };
    reveal();
    window.addEventListener('scroll', reveal, { passive: true });
  }
</script>
