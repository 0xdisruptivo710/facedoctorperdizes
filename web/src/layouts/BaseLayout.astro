---
/**
 * BaseLayout - shell raiz de todas as páginas.
 * Define <head>, fontes, meta tags, Schema.org básico (LocalBusiness + MedicalBusiness).
 */
import '../styles/tokens.css';
import '../styles/reset.css';
import '../styles/primitives.css';

interface Props {
  title: string;
  description: string;
  /** Path relativo da imagem OG (default: hero da home) */
  ogImage?: string;
  /** Canonical absoluto (default: derivado de Astro.site + pathname) */
  canonical?: string;
  /** Schema.org adicional para procedimentos */
  procedureSchema?: object;
}

const {
  title,
  description,
  ogImage = '/og-default.jpg',
  canonical,
  procedureSchema,
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonicalUrl = canonical ?? `${site}${Astro.url.pathname}`;
const ogUrl = ogImage.startsWith('http') ? ogImage : `${site}${ogImage}`;

// Schema.org LocalBusiness + MedicalBusiness (DESIGN.md §10)
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': ['MedicalBusiness', 'LocalBusiness'],
  name: 'Face Doctor Perdizes',
  description: 'Clínica de estética facial em Perdizes, São Paulo. Unidade autorizada da rede Face Doctor.',
  url: site,
  telephone: '+55-11-94062-5771',
  priceRange: '$$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'R. Piracuama, 138',
    addressLocality: 'São Paulo',
    addressRegion: 'SP',
    postalCode: '05017-040',
    addressCountry: 'BR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -23.535,
    longitude: -46.682,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '09:00',
    closes: '20:00',
  },
  sameAs: [
    'https://www.instagram.com/facedoctor.perdizes',
  ],
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <meta name="theme-color" content="#1F1B1C" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Fonts v3.1: Playfair Display (serif display) + Roboto (sans body) + Roboto Mono (labels). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Roboto:wght@300;400;500;700&family=Roboto+Mono:wght@300;400&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
    {procedureSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(procedureSchema)} />}
  </head>

  <body>
    <a href="#main" class="skip-link">Pular para o conteúdo</a>

    <slot name="header" />

    <main id="main">
      <slot />
    </main>

    <slot name="footer" />
    <slot name="floats" />

    <script>
      // Reveal-on-scroll observer (DESIGN.md §4.1)
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
      );

      const init = () => {
        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    </script>

    <style is:global>
      .skip-link {
        position: absolute;
        top: -100px;
        left: var(--space-4);
        z-index: 999;
        padding: var(--space-3) var(--space-5);
        background-color: var(--ink);
        color: var(--paper);
        font-family: var(--font-mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: var(--track-mono);
        border-radius: var(--radius-sm);
        transition: top var(--dur-fast) var(--ease-out);
      }
      .skip-link:focus-visible { top: var(--space-4); }
    </style>
  </body>
</html>
